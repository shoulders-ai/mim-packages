{
  "name": "@mim/knowledge",
  "version": "0.1.1",
  "type": "module",
  "mim": {
    "manifestVersion": 1,
    "id": "knowledge",
    "name": "Knowledge",
    "icon": "./ui/icon.svg",
    "description": "Knowledge base",
    "views": [
      { "id": "main", "label": "Knowledge", "src": "./ui/index.html", "role": "work" }
    ],
    "backend": "./backend/index.mjs",
    "permissions": {
      "workspace": { "read": true, "write": true }
    },
    "provides": {
      "tools": [
        { "name": "knowledge.list", "category": "read", "risk": "low" },
        { "name": "knowledge.get", "category": "read", "risk": "low" },
        { "name": "knowledge.create", "category": "write", "risk": "medium" },
        { "name": "knowledge.update", "category": "write", "risk": "medium" },
        { "name": "knowledge.delete", "category": "write", "risk": "high" }
      ]
    },
    "dataFolder": "knowledge",
    "engines": { "mim": "runtime-v1" }
  }
}
